plex:
  url: http://127.0.0.1:32400
  token: "YOUR_PLEX_TOKEN"
  user_tokens:
    alice: "ALICE_PLEX_TOKEN"
    bob: "BOB_PLEX_TOKEN"
  user_emails:
    admin: admin@example.com
    alice: alice@example.com
    bob: bob@example.com

sonarr:
  url: http://127.0.0.1:8989
  api_key: "YOUR_SONARR_KEY"

radarr:
  url: http://127.0.0.1:7878
  api_key: "YOUR_RADARR_KEY"

medusa:
  url: http://127.0.0.1:8081
  api_key: "YOUR_MEDUSA_KEY"

ombi:
  url: http://127.0.0.1:5000
  api_key: "YOUR_OMBI_KEY"

web:
  secret_key: "CHANGE_ME_RANDOM_SECRET"
  admin_password: ""  # bcrypt hash; generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt()).decode())"
  base_url: "https://mediapurge.example.com:9393"
  port: 9393
  ssl_cert: /opt/mediapurge/ssl/fullchain.pem
  ssl_key: /opt/mediapurge/ssl/privkey.pem

notifications:
  enabled: false
  method: email  # email | discord
  email:
    from: mediapurge@example.com
    admin: admin@example.com
    smtp_host: smtp.example.com
    smtp_port: 587
    smtp_user: ""
    smtp_pass: ""
  discord:
    webhook_url: ""

maintenance:
  dry_run: true
  schedule: "03:00"
  log_file: /var/log/mediapurge.log
  excluded_libraries:
    - "3D Movies"

database:
  path: mediapurge.db
